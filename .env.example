# ============================================================
# TeaParty-Bell (小G宝) 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ============================================================

# --- Discord ---
# Discord Bot Token（从 Discord Developer Portal 获取）
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord Application ID
DISCORD_APPLICATION_ID=your_application_id_here

# 目标服务器 ID
DISCORD_GUILD_ID=your_guild_id_here

# 感谢消息发送频道 ID
DISCORD_THANKS_CHANNEL_ID=your_channel_id_here

# --- DeepSeek AI ---
# DeepSeek API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API 地址（默认官方地址）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek 模型名称（deepseek-v4-flash 或 deepseek-v4-pro）
# 注意：deepseek-chat / deepseek-reasoner 将于 2026-07-24 退役
DEEPSEEK_MODEL=deepseek-v4-flash

# --- 应用行为 ---
# 测试模式：true 时不发送真实消息，日志输出本应发送的内容
TEST_MODE=false

# 日志等级：error | warn | info | debug
LOG_LEVEL=info

# Reaction 数量（默认 8）
REACTION_COUNT=8
